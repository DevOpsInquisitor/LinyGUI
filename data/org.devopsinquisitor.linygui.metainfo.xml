<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.devopsinquisitor.linygui</id>
  <name>LinyGUI</name>
  <summary>Elegant image compression powered by TinyPNG</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <developer id="org.devopsinquisitor">
    <name>DevOpsInquisitor</name>
  </developer>
  <description>
    <p>
      LinyGUI is a modern, beautifully designed desktop application for compressing
      and resizing images using the TinyPNG API. It features a stunning glassmorphism
      dark UI with smooth animations.
    </p>
    <p>Features:</p>
    <ul>
      <li>Smart lossless-quality PNG, JPEG, and WebP compression</li>
      <li>Intelligent resize modes: Scale, Fit, Cover, and Thumb</li>
      <li>Drag-and-drop support for quick processing</li>
      <li>Batch processing with progress tracking</li>
      <li>Optional metadata preservation (copyright, GPS, dates)</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/DevOpsInquisitor/linygui</url>
  <launchable type="desktop-id">org.devopsinquisitor.linygui.desktop</launchable>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="1.0.0" date="2026-05-19">
      <description>
        <p>Initial release of LinyGUI.</p>
      </description>
    </release>
  </releases>
  <requires>
    <internet>always</internet>
  </requires>
</component>
