{
    "app-id": "org.devopsinquisitor.linygui",
    "runtime": "org.gnome.Platform",
    "runtime-version": "46",
    "sdk": "org.gnome.Sdk",
    "command": "linygui",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--talk-name=org.freedesktop.secrets"
    ],
    "modules": [
        {
            "name": "linygui",
            "buildsystem": "simple",
            "build-commands": [
                "install -D -m 755 src/main.py ${FLATPAK_DEST}/bin/linygui",
                "chmod +x ${FLATPAK_DEST}/bin/linygui",
                "install -D -m 644 src/window.py ${FLATPAK_DEST}/lib/linygui/window.py",
                "install -Dm644 src/tinify.py ${FLATPAK_DEST}/lib/linygui/tinify.py",
                "install -Dm644 src/linygui.css ${FLATPAK_DEST}/lib/linygui/linygui.css",
                "install -Dm644 src/__init__.py ${FLATPAK_DEST}/lib/linygui/__init__.py",
                "install -Dm644 data/org.devopsinquisitor.linygui.desktop ${FLATPAK_DEST}/share/applications/org.devopsinquisitor.linygui.desktop",
                "install -Dm644 data/org.devopsinquisitor.linygui.metainfo.xml ${FLATPAK_DEST}/share/metainfo/org.devopsinquisitor.linygui.metainfo.xml",
                "install -Dm644 icon.png ${FLATPAK_DEST}/share/icons/hicolor/512x512/apps/org.devopsinquisitor.linygui.png"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/DevOpsInquisitor/LinyGUI.git",
                    "tag": "v1.1.3"
                }
            ]
        }
    ]
}